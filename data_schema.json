{
  "voterEligibilityRules": {
    "resident": {
      "minimumAge": 18,
      "citizenshipRequired": true,
      "residencyStatus": "ordinarily_resident",
      "requiredDocuments": [
        "Aadhaar_Card",
        "PAN_Card",
        "Proof_of_Address"
      ],
      "verificationMethod": "otp_and_biometric",
      "votingMethodAllowed": ["evm_at_polling_booth"]
    },
    "nri": {
      "minimumAge": 18,
      "citizenshipRequired": true,
      "residencyStatus": "non_resident_indian",
      "requiredDocuments": [
        "Indian_Passport_Copy",
        "Valid_Visa_Status",
        "Overseas_Address_Proof"
      ],
      "verificationMethod": "embassy_attestation",
      "votingMethodAllowed": ["eTPBS", "proxy_voting"]
    }
  },
  "registrationPhases": [
    {
      "phaseId": "phase_1",
      "phaseName": "Eligibility Check",
      "description": "Determine if the user is a Resident or NRI and verify basic age/citizenship requirements.",
      "requiredFields": ["dateOfBirth", "citizenshipStatus", "residencyType"]
    },
    {
      "phaseId": "phase_2",
      "phaseName": "Document Upload",
      "description": "Upload required identification and address proofs based on eligibility type.",
      "requiredFields": ["documentFiles", "documentNumbers"]
    },
    {
      "phaseId": "phase_3",
      "phaseName": "AI Verification",
      "description": "Automated OCR and AI-based cross-referencing of uploaded documents.",
      "requiredFields": ["aiConfidenceScore", "verificationStatus"]
    },
    {
      "phaseId": "phase_4",
      "phaseName": "EPIC Generation",
      "description": "Generation of the digital Electoral Photo Identity Card (EPIC).",
      "requiredFields": ["epicNumber", "digitalCardUrl"]
    }
  ],
  "historicalIncidentData": {
    "schemaDescription": "Structure for historical security incidents to train/inform the AI security module.",
    "incidentStructure": {
      "incidentId": "string (UUID)",
      "timestamp": "ISO 8601 Date String",
      "location": {
        "state": "string",
        "constituency": "string",
        "pollingStationCode": "string",
        "coordinates": {
          "lat": "number",
          "lng": "number"
        }
      },
      "severity": "enum('low', 'medium', 'high', 'critical')",
      "incidentCategory": "enum('evm_malfunction', 'voter_intimidation', 'fake_voting', 'violence', 'procedural_delay')",
      "incidentSummary": "string",
      "resolutionStatus": "enum('open', 'investigating', 'resolved')"
    },
